# ============================================
# Frontend (SvelteKit/Node.js) - .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# SvelteKit
.svelte-kit/
build/
Frontend/.svelte-kit/

# Build outputs
dist/
.output/

# Environment variables
.env
.env.*
!.env.example
.envrc

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.cursor/
.cursorignore
.cursorindexingignore

# Testing
coverage/
.nyc_output/
*.lcov

# Temporary files
*.tmp
*.temp
.cache/

# Documentation (not needed for deployment)
SETUP_INSTRUCTIONS.md
BACKEND_INTEGRATION.md

# Package manager
.npm
.yarn-integrity
.pnp.*
# Uncomment if this is a library (keep committed for applications)
# package-lock.json
yarn.lock
pnpm-lock.yaml
